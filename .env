# IETS LMS - MySQL Configuration

# Server Configuration
PORT=5000
NODE_ENV=production
API_URL=http://localhost:5000

# MySQL Database Configuration
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_DATABASE=iets_lms
MYSQL_PORT=3306

# JWT Configuration
JWT_SECRET=iets_secret_key_change_this_in_production_12345678901234567890
JWT_EXPIRE=7d

# Company Information
COMPANY_NAME=IETS
COMPANY_WEBSITE=https://iets.edu
SCHOOL_NAME=International Educational Technology School

# Email Configuration (Optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# CORS
CORS_ORIGIN=*

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads